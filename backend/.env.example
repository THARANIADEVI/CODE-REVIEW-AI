SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
# Leave DATABASE_URL unset to use the zero-setup local SQLite file.
# For Supabase Postgres, use the connection string from
# Project Settings > Database > Connection string (URI, "Session pooler" for serverless):
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=
# LLM for AI code review + auto-refactor: Mistral AI (https://console.mistral.ai/api-keys).
# Leave MISTRAL_API_KEY empty to run on the offline heuristic reviewer instead.
# MISTRAL_MODEL can be any Mistral model id, e.g. open-mistral-7b, mistral-small-latest,
# mistral-medium-latest, mistral-large-latest.
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# Comma-separated origins allowed to call this API, e.g. your Vercel frontend URL.
# Leave as * for local dev.
CORS_ORIGINS=*
FRONTEND_URL=http://localhost:5173


SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
# Leave DATABASE_URL unset to use the zero-setup local SQLite file.
# For Supabase Postgres, use the connection string from
# Project Settings > Database > Connection string (URI, "Session pooler" for serverless):
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Comma-separated origins allowed to call this API, e.g. your Vercel frontend URL.
# Leave as * for local dev.
CORS_ORIGINS=*
FRONTEND_URL=http://localhost:5173

# GitHub OAuth app credentials (https://github.com/settings/developers).
# Authorization callback URL on the GitHub app must match GITHUB_OAUTH_REDIRECT_URI.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5000/api/oauth/github/callback

# Optional: enables the "email notification after analysis" feature.
# Leave SMTP_HOST empty to disable (no-op) without any error.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
